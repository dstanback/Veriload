# ==============================================================================
# Veriload — Environment Variables
# Copy this file to .env.local and fill in the values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (REQUIRED)
# ------------------------------------------------------------------------------
# Pooled connection string — used at runtime by Prisma Client.
# For Vercel Postgres / Neon / Supabase, this is the pooler URL (port 6543).
DATABASE_URL=postgresql://user:pass@host:5432/veriload

# Direct (non-pooled) connection string — used by Prisma Migrate / db push.
# Required when the primary DATABASE_URL goes through a connection pooler.
# For Vercel Postgres, use the "Direct" connection string from the dashboard.
# Locally you can set this to the same value as DATABASE_URL.
DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/veriload

# ------------------------------------------------------------------------------
# Application (REQUIRED for production)
# ------------------------------------------------------------------------------
NODE_ENV=development

# Public-facing app URL — used for absolute URL construction, CORS, and redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=

# ------------------------------------------------------------------------------
# File Storage (S3-compatible — optional, falls back to local .veriload-storage/)
# ------------------------------------------------------------------------------
STORAGE_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=veriload-docs
STORAGE_PUBLIC_BASE_URL=

# ------------------------------------------------------------------------------
# AI / LLM (optional — enables vision extraction and dispute email generation)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CLASSIFIER_MODEL=claude-3-5-haiku-latest
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-5-latest
ANTHROPIC_CLASSIFIER_INPUT_COST_PER_MILLION_TOKENS=80
ANTHROPIC_CLASSIFIER_OUTPUT_COST_PER_MILLION_TOKENS=400
ANTHROPIC_EXTRACTION_INPUT_COST_PER_MILLION_TOKENS=300
ANTHROPIC_EXTRACTION_OUTPUT_COST_PER_MILLION_TOKENS=1500

# ------------------------------------------------------------------------------
# Email (optional — enables outbound transactional emails and inbound ingestion)
# ------------------------------------------------------------------------------
# SendGrid API key — used for both outbound sending and inbound webhook auth.
# If not set, outbound emails are logged to console instead of sending.
SENDGRID_API_KEY=
# Default "from" address for outbound emails (disputes, daily summaries).
EMAIL_FROM=notifications@veriload.app
SENDGRID_INBOUND_WEBHOOK_SECRET=
SENDGRID_WEBHOOK_VERIFICATION_KEY=
EMAIL_DOMAIN=veriload.local

# ------------------------------------------------------------------------------
# Queue / Workers (optional — enables async document processing)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
PROCESS_DOCUMENT_CONCURRENCY=4
RECONCILE_CONCURRENCY=8

# ------------------------------------------------------------------------------
# PDF Rendering
# ------------------------------------------------------------------------------
PDF_RENDER_DPI=220

# ------------------------------------------------------------------------------
# Dev-only defaults (ignored in production)
# ------------------------------------------------------------------------------
DEV_USER_EMAIL=ops@acmefreight.com
DEV_USER_NAME=Maya Patel
DEV_ORG_NAME=Acme Logistics
DEV_ORG_SLUG=acme
